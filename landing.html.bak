<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Comelones - Restaurante Gourmet</title>
  <link rel="stylesheet" href="style.css">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=Playfair+Display:wght@400;600&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

    <nav class="navbar">
        <div class="logo-container">
            <img src="./imagenesRestaurante/logor.png" alt="Logo Comelones" class="logo-img">
            <div class="logo-text">Comelones<span>.</span></div>
        </div>
        
        <ul class="nav-links">
            <li><a href="#inicio">Inicio</a></li>
            <li><a href="#menu">Menú</a></li>
            <li><a href="#nosotros">Nosotros</a></li>
            <li><a href="#contacto">Contacto</a></li>
            <li><a href="#reserva" class="btn-reserva-nav">Reservar</a></li>
        </ul>
    </nav>

    <section id="inicio" class="carousel-container">
        <div class="slider">
            <div class="slide active">
                <img src="./imagenesRestaurante/Cocinero.jpg" alt="Nuestro chef estrella terminando un plato">
                <div class="info">
                    <h1>Sabor Auténtico</h1>
                    <p>Descubre la verdadera esencia de la cocina artesanal.</p>
                    <a href="#menu" class="btn-carousel">Ver Menú</a>
                </div>
            </div>
            <div class="slide">
                <img src="./imagenesRestaurante/cena.jpg" alt="Nuestros mejores platos">
                <div class="info">
                    <h1>Ambiente Único</h1>
                    <p>El lugar perfecto para tus momentos especiales.</p>
                    <a href="#reserva" class="btn-carousel">Reservar Mesa</a>
                </div>
            </div>
            <div class="slide">
                <img src="./imagenesRestaurante/maridaje.jpg" alt="Experiencias de Maridaje">
                <div class="info">
                    <h1>Experiencia Gourmet</h1>
                    <p>Bebidas y postres que sorprenderán tus sentidos.</p>
                    <a href="#menu" class="btn-carousel">Explorar</a>
                </div>
            </div>
        </div>

        <button class="prev" onclick="changeSlide(-1)">&#10094;</button>
        <button class="next" onclick="changeSlide(1)">&#10095;</button>

        <div class="dots-container">
            <span class="dot active" onclick="currentSlide(0)"></span>
            <span class="dot" onclick="currentSlide(1)"></span>
            <span class="dot" onclick="currentSlide(2)"></span>
        </div>
    </section>

    <section class="quick-access-bar">
        <div class="quick-access-container">
            
            <a href="#menu" class="quick-card">
                <div class="icon-circle">
                    <i class="fas fa-utensils"></i> </div>
                <span>Menú</span>
            </a>

            <a href="#reserva" class="quick-card">
                <div class="icon-circle">
                    <i class="fas fa-calendar-alt"></i> </div>
                <span>Reservas</span>
            </a>

            <a href="#resenas" class="quick-card">
                <div class="icon-circle">
                    <i class="fas fa-star"></i> </div>
                <span>Reseñas</span>
            </a>

            <a href="#contacto" class="quick-card">
                <div class="icon-circle">
                    <i class="fas fa-phone-alt"></i> </div>
                <span>Contacto</span>
            </a>

        </div>
    </section>

    <section id="menu" class="menu-section">
        <div class="menu-header">
            <h1 class="titulo-principal">Nuestro Menú Gastronómico</h1>
            <p class="menu-subtitle">Descubre nuestras creaciones culinarias seleccionadas especialmente para deleitarte</p>
        </div>

        <div class="filtros">
            <button class="btn-filtro active" onclick="filtrarMenu('Todos')">Todos</button>
            <button class="btn-filtro" onclick="filtrarMenu('Entradas')">Entradas</button>
            <button class="btn-filtro" onclick="filtrarMenu('Platos Fuertes')">Platos Fuertes</button>
            <button class="btn-filtro" onclick="filtrarMenu('Bebidas')">Bebidas</button>
        </div>

        <div id="contenedor-menu" class="grid-menu">
        </div>

        <div class="download-menu-container">
            <button class="btn-download-menu" onclick="descargarMenu()">
                <div class="menu-icon-wrapper">
                    <i class="fas fa-book-open"></i>
                </div>
                <span>Descargar Menú</span>
                <div class="btn-glow"></div>
            </button>
        </div>
    </section>

    <section id="nosotros" class="contenedor-nosotros">
        <div class="texto-nosotros">
            <h2>Nuestra Cocina</h2>
            <p>En Comelones nos apasiona crear momentos inolvidables a través de ingredientes frescos y recetas tradicionales con un toque moderno.</p>
        </div>
        <div class="carrusel-eventos">
            <div class="slider-eventos">
                <div class="slide-evento active">
                    <img src="https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?w=600" alt="Evento 1">
                </div>
                <div class="slide-evento">
                    <img src="https://images.unsplash.com/photo-1504674900174-2155a13de972?w=600" alt="Evento 2">
                </div>
                <div class="slide-evento">
                    <img src="https://images.unsplash.com/photo-1555939594-58d7cb561ad1?w=600" alt="Evento 3">
                </div>
                <div class="slide-evento">
                    <img src="https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=600" alt="Evento 4">
                </div>
            </div>
            
            <button class="prev-evento" onclick="cambiarSlideEvento(-1)">&#10094;</button>
            <button class="next-evento" onclick="cambiarSlideEvento(1)">&#10095;</button>
            
            <div class="dots-eventos">
                <span class="dot-evento active" onclick="seleccionarSlideEvento(0)"></span>
                <span class="dot-evento" onclick="seleccionarSlideEvento(1)"></span>
                <span class="dot-evento" onclick="seleccionarSlideEvento(2)"></span>
                <span class="dot-evento" onclick="seleccionarSlideEvento(3)"></span>
            </div>
        </div>
    </section>


    <section id="reserva" class="reserva-section">
        <div class="reserva-header">
            <h2>Realizar Reserva</h2>
            <p>Vive una experiencia gastronómica inolvidable en Comelones</p>
        </div>

        <div class="reserva-container">
            <!-- Formulario de Reserva -->
            <form class="form-reserva">
                <div class="form-group">
                    <label>Nombre Completo *</label>
                    <input type="text" placeholder="Ej: Juan Pérez" required>
                </div>
                
                <div class="form-group">
                    <label>Email *</label>
                    <input type="email" placeholder="tu@email.com" required>
                </div>
                
                <div class="form-group">
                    <label>Teléfono *</label>
                    <input type="tel" placeholder="+57 123 456 7890" required>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Fecha *</label>
                        <input type="date" required>
                    </div>
                    <div class="form-group">
                        <label>Hora *</label>
                        <input type="time" required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Personas *</label>
                        <select required>
                            <option value="">Selecciona</option>
                            <option>1 persona</option>
                            <option>2 personas</option>
                            <option>3 personas</option>
                            <option>4 personas</option>
                            <option>5 personas</option>
                            <option>6+ personas</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Tipo de Mesa</label>
                        <select>
                            <option value="">Cualquier mesa</option>
                            <option>Mesa Standard</option>
                            <option>Mesa VIP</option>
                            <option>Mesa Terraza</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Ocasión Especial (Opcional)</label>
                    <select>
                        <option value="">Selecciona una ocasión</option>
                        <option>Cumpleaños</option>
                        <option>Aniversario</option>
                        <option>Cena Romántica</option>
                        <option>Reunión Empresarial</option>
                        <option>Otra</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Preferencias o Alergias (Opcional)</label>
                    <textarea placeholder="Déjanos saber cualquier preferencia o alergia..." rows="3"></textarea>
                </div>

                <div class="form-check">
                    <input type="checkbox" id="terminos" required>
                    <label for="terminos">Autorizo a Comelones a contactarme para confirmar mi reserva</label>
                </div>

                <button type="submit" class="btn-reservar">Confirmar Reserva</button>
            </form>

            <!-- Información Importante -->
            <div class="info-reserva">
                <h3>Información Importante</h3>
                
                <div class="info-item">
                    <i class="fas fa-clock"></i>
                    <div>
                        <h4>Horarios</h4>
                        <p>Lunes - Viernes: 12:00 PM - 10:00 PM</p>
                        <p>Sábado - Domingo: 11:30 AM - 11:00 PM</p>
                    </div>
                </div>

                <div class="info-item">
                    <i class="fas fa-users"></i>
                    <div>
                        <h4>Capacidad</h4>
                        <p>Mínimo 1 persona</p>
                        <p>Máximo 50 personas</p>
                    </div>
                </div>

                <div class="info-item">
                    <i class="fas fa-ban"></i>
                    <div>
                        <h4>Cancelación</h4>
                        <p>Cancelar con 24 horas de anticipación</p>
                        <p>Sin costo de cancelación</p>
                    </div>
                </div>

                <div class="info-item">
                    <i class="fas fa-phone-alt"></i>
                    <div>
                        <h4>Contacto Directo</h4>
                        <p>Teléfono: +57 123 456 7890</p>
                        <p>WhatsApp: +57 123 456 7890</p>
                    </div>
                </div>

                <div class="info-item">
                    <i class="fas fa-check-circle"></i>
                    <div>
                        <h4>Qué Esperar</h4>
                        <p>Confirmación en 2 horas</p>
                        <p>Recordatorio 24 horas antes</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="resenas" class="resenas-section">
        <div class="resenas-header">
            <h2>Reseñas de Clientes</h2>
            <p>Descubre qué piensan otros comensales de Comelones</p>
        </div>

        <div class="resenas-container">
            <!-- Formulario para Agregar Reseña -->
            <div class="nueva-resena">
                <h3>Comparte tu Experiencia</h3>
                <form class="form-resena">
                    <div class="form-group">
                        <label>Tu Nombre *</label>
                        <input type="text" class="input-nombre" placeholder="Ej: María García" required>
                    </div>

                    <div class="form-group">
                        <label>Tu Comentario *</label>
                        <textarea class="textarea-comentario" placeholder="Cuéntanos tu experiencia en Comelones..." rows="4" required></textarea>
                    </div>

                    <div class="form-group">
                        <label>Calificación *</label>
                        <div class="stars-input">
                            <span class="star" data-value="1">★</span>
                            <span class="star" data-value="2">★</span>
                            <span class="star" data-value="3">★</span>
                            <span class="star" data-value="4">★</span>
                            <span class="star" data-value="5">★</span>
                        </div>
                        <input type="hidden" class="calificacion-input" value="0" required>
                        <span class="calificacion-texto">Selecciona una calificación</span>
                    </div>

                    <button type="submit" class="btn-publicar-resena">Publicar Reseña</button>
                </form>
            </div>

            <!-- Listado de Reseñas -->
            <div class="listado-resenas">
                <h3>Lo que dicen nuestros clientes</h3>
                <div id="contenedor-resenas" class="resenas-grid">
                    <!-- Las reseñas se cargarán aquí dinámicamente -->
                </div>
            </div>
        </div>
    </section>

    <section id="contacto" class="contacto-section">
        <h2>Contacto</h2>
        <p>Calle Gastronómica #123, Bucaramanga</p>
        <p>Teléfono: +57 123 456 7890</p>
        <p>Email: info@comelones.com</p>
    </section>

    <footer class="footer">
        <div class="footer-grid">
            <div class="footer-info">
                <h3>Comelones</h3>
                <p>Calle Gastronómica #123, Bucaramanga.</p>
            </div>
            <div class="footer-links">
                <h4>Enlaces</h4>
                <a href="#">Privacidad</a>
                <a href="#">Términos</a>
            </div>
            <div class="footer-social">
                <h4>Síguenos</h4>
                <div class="redes">
                    <span>FB</span> <span>IG</span> <span>TW</span>
                </div>
            </div>
        </div>
        <p class="copy">&copy; 2026 Restaurante Comelones - Proyecto Académico</p>
    </footer>

  <script src="landing.js"></script>
</body>
</html>